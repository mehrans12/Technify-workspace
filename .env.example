# Firebase Configuration
# Copy this file to .env and replace with your actual Firebase credentials
# Get values from: https://console.firebase.google.com → Project Settings
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# GitHub OAuth Configuration
# Create OAuth App at: https://github.com/settings/developers
# Application name: Technify IDE
# Homepage URL: http://localhost:5173 (or your domain)
# Authorization callback URL: http://localhost:4000/api/github/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URI=http://localhost:4000/api/github/callback

# Token Encryption (MUST be exactly 32 characters for AES-256-CBC)
ENCRYPTION_KEY=technify_collab_ide_secret_key_32

# AI Assistant API (OpenRouter)
# Get API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1_your_openrouter_key_here

# Server Configuration
PORT=4000
VITE_SERVER_URL=http://localhost:4000
VITE_COLLAB_WS_URL=ws://localhost:4000

# Production URLs (uncomment and update when deploying)
# VITE_SERVER_URL=https://your-production-domain.com
# VITE_COLLAB_WS_URL=wss://your-production-domain.com
# GITHUB_REDIRECT_URI=https://your-production-domain.com/api/github/callback
